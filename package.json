{
  "name": "spyglass",
  "displayName": "Spyglass",
  "description": "Fast file and text search popup inspired by Neovim Telescope and JetBrains Finder",
  "version": "0.2.1",
  "publisher": "garroter",
  "license": "MIT",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "search",
    "finder",
    "spyglass",
    "telescope",
    "grep",
    "fuzzy",
    "ripgrep",
    "file search",
    "text search",
    "symbol search",
    "replace",
    "popup",
    "quick open",
    "neovim",
    "jetbrains"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/garroter/spyglass"
  },
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "spyglass-sidebar",
          "title": "Spyglass",
          "icon": "images/icon.svg"
        }
      ]
    },
    "views": {
      "spyglass-sidebar": [
        {
          "id": "spyglass.sidebarView",
          "name": "Spyglass",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "spyglass.open",
        "title": "Spyglass: Open Search Popup"
      },
      {
        "command": "spyglass.focusSidebar",
        "title": "Spyglass: Focus Sidebar Panel"
      }
    ],
    "keybindings": [
      {
        "command": "spyglass.open",
        "key": "ctrl+alt+f",
        "mac": "cmd+alt+f",
        "when": "!inputFocus || editorTextFocus"
      },
      {
        "command": "spyglass.open",
        "key": "space f",
        "when": "editorTextFocus && neovim.mode == 'normal'"
      },
      {
        "command": "spyglass.focusSidebar",
        "key": "ctrl+alt+e",
        "mac": "cmd+alt+e"
      }
    ],
    "configuration": {
      "title": "Spyglass",
      "properties": {
        "spyglass.ripgrepPath": {
          "type": "string",
          "default": "",
          "description": "Path to ripgrep binary. Leave empty to use bundled version."
        },
        "spyglass.maxResults": {
          "type": "number",
          "default": 200,
          "description": "Maximum number of search results to display."
        },
        "spyglass.defaultScope": {
          "type": "string",
          "enum": [
            "project",
            "openFiles",
            "files",
            "recent",
            "here",
            "symbols",
            "git",
            "doc",
            "refs"
          ],
          "default": "project",
          "description": "Default search scope when Finder opens."
        },
        "spyglass.keybindings.navigateDown": {
          "type": "string",
          "default": "ArrowDown",
          "description": "Key to navigate down in results (e.g. 'ArrowDown', 'j')."
        },
        "spyglass.keybindings.navigateUp": {
          "type": "string",
          "default": "ArrowUp",
          "description": "Key to navigate up in results (e.g. 'ArrowUp', 'k')."
        },
        "spyglass.keybindings.open": {
          "type": "string",
          "default": "Enter",
          "description": "Key to open the selected result."
        },
        "spyglass.keybindings.close": {
          "type": "string",
          "default": "Escape",
          "description": "Key to close Finder."
        },
        "spyglass.keybindings.toggleRegex": {
          "type": "string",
          "default": "shift+alt+r",
          "description": "Key combination to toggle regex mode (e.g. 'shift+alt+r')."
        },
        "spyglass.keybindings.togglePreview": {
          "type": "string",
          "default": "shift+alt+p",
          "description": "Key combination to toggle preview panel (e.g. 'shift+alt+p')."
        },
        "spyglass.openOnSide": {
          "type": "boolean",
          "default": false,
          "description": "Open Spyglass in a side column instead of the active editor column."
        },
        "spyglass.exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            ".git",
            "node_modules",
            "out",
            "dist",
            "*.lock"
          ],
          "description": "Glob patterns to exclude from search and file listing (e.g. \"vendor\", \"build\", \"*.min.js\"). Replaces the built-in defaults."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run bundle-webview",
    "compile": "tsc -p ./",
    "bundle-webview": "node esbuild.webview.mjs",
    "watch": "tsc -watch -p ./",
    "watch-webview": "node esbuild.webview.mjs --watch",
    "lint": "eslint src --ext ts",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "esbuild": "^0.27.4",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@vscode/ripgrep": "^1.17.0",
    "highlight.js": "^11.11.1"
  }
}
